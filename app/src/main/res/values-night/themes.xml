<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme for dark mode -->
    <style name="Base.Theme.PrayerZones" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Dark theme customization -->
        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Main app theme - inherits dark mode -->
    <style name="Theme.PrayerZones" parent="Base.Theme.PrayerZones" />

    <!-- Settings theme for dark mode -->
    <style name="Theme.PrayerZones.Settings" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Use lighter purple for headers (category titles) for better visibility in dark mode -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_500</item>
        <item name="colorSecondary">@color/purple_200</item>

        <!-- Dark mode background and text -->
        <item name="android:windowBackground">@android:color/black</item>
        <item name="colorSurface">@android:color/black</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Preference text colors for dark mode -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@android:color/darker_gray</item>

        <!-- Override preference theme to customize category title size -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.Settings.Dark</item>

        <!-- Status and navigation bars — managed by Compose Theme at runtime -->
        <!-- <item name="android:statusBarColor">@color/black</item> -->
        <!-- <item name="android:navigationBarColor">@color/black</item> -->

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Preference theme overlay to make category titles same size as preference titles -->
    <style name="PreferenceThemeOverlay.Settings.Dark" parent="PreferenceThemeOverlay.v14.Material">
        <item name="preferenceCategoryTitleTextAppearance">@style/PreferenceCategoryTitleTextAppearance.Dark</item>
    </style>

    <!-- Custom text appearance for category titles - same size as preference titles -->
    <style name="PreferenceCategoryTitleTextAppearance.Dark" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>

