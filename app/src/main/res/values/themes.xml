<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ Your original theme name, fixed with valid parent -->
    <style name="Base.Theme.PrayerZones" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here -->
        <!-- Example color overrides -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- ✅ Inherit into main app theme -->
    <style name="Theme.PrayerZones" parent="Base.Theme.PrayerZones" />

    <!-- Optional: Activity-specific theme -->
    <style name="MyActivityTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorPrimaryDark">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>

    <!-- Settings-only theme: force app purple palette and avoid dynamic (Material You) colors -->
    <style name="Theme.PrayerZones.Settings" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Keep purple accent for headers (category titles) -->
        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorPrimaryVariant">@color/purple_900</item>
        <item name="colorSecondary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Light mode background and text -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@android:color/black</item>

        <!-- Preference text colors for light mode -->
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:textColorSecondary">@android:color/darker_gray</item>

        <!-- Override preference theme to customize category title size -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.Settings</item>

        <!-- Status and navigation bars — managed by Compose Theme at runtime -->
        <!-- <item name="android:statusBarColor">@color/black</item> -->
        <!-- <item name="android:navigationBarColor">@color/black</item> -->

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Preference theme overlay to make category titles same size as preference titles -->
    <style name="PreferenceThemeOverlay.Settings" parent="PreferenceThemeOverlay.v14.Material">
        <item name="preferenceCategoryTitleTextAppearance">@style/PreferenceCategoryTitleTextAppearance</item>
    </style>

    <!-- Custom text appearance for category titles - same size as preference titles -->
    <style name="PreferenceCategoryTitleTextAppearance" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
